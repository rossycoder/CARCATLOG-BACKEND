# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/car-website

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email Configuration
# Options: 'sendgrid' or 'gmail'
# RECOMMENDED: Use 'gmail' with Gmail Workspace for business emails
EMAIL_SERVICE=gmail
EMAIL_FROM=CarCatalog <noreply@carcatalog.com>

# SendGrid Configuration (alternative option - requires domain authentication)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Gmail Configuration (RECOMMENDED)
# For Gmail Workspace: use your business email (e.g., noreply@carcatalog.com)
# For regular Gmail: use your Gmail address with App Password
# How to get App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Create new App Password for "Mail"
# 5. Copy the 16-character password and paste below
EMAIL_USER=noreply@carcatalog.com
EMAIL_PASSWORD=your-16-character-app-password-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# Apple Sign In
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./apple-private-key.p8
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/apple/callback

# Frontend URL
FRONTEND_URL=http://localhost:3000

# UK Postcode API
POSTCODE_API_URL=https://api.postcodes.io

# CheckCardDetails API Configuration
# This API provides comprehensive vehicle data including specs, history, and valuation
# Get your API key from the client
# Base URL: https://api.checkcarddetails.co.uk
# Endpoint format: /vehicledata/{Datapoint}?apikey={API_KEY}&vrm={Registration}
# Available datapoints: ukvehicledata, Vehiclespecs, vehiclevaluation, mot, carhistorycheck
CHECKCARD_API_KEY=your-checkcarddetails-api-key-here
CHECKCARD_API_TEST_KEY=your-test-api-key-here
CHECKCARD_API_BASE_URL=https://api.checkcarddetails.co.uk

# Legacy API Configuration (for backward compatibility)
# Vehicle History API Configuration
HISTORY_API_LIVE_KEY=your-live-history-api-key-here
HISTORY_API_TEST_KEY=your-test-history-api-key-here
HISTORY_API_BASE_URL=https://api.checkcarddetails.co.uk
HISTORY_API_TEST_BASE_URL=https://api.checkcarddetails.co.uk

# Vehicle Valuation API Configuration
VALUATION_API_LIVE_KEY=your-live-valuation-api-key-here
VALUATION_API_TEST_KEY=your-test-valuation-api-key-here
VALUATION_API_BASE_URL=https://api.checkcarddetails.co.uk
VALUATION_API_TEST_BASE_URL=https://api.checkcarddetails.co.uk

# API Environment (test or production)
API_ENVIRONMENT=test

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here
STRIPE_PRICE_ID=price_your-stripe-price-id-for-495-gbp
