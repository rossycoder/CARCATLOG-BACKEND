# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file, fill in values, set in Render dashboard
# NEVER commit the actual .env file to git
# ============================================================

# Server
PORT=10000
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/car-website?retryWrites=true&w=majority

# JWT - Use a strong random string (min 32 chars)
JWT_SECRET=<generate-strong-secret-here>
JWT_EXPIRE=7d

# Frontend URL (your Render frontend URL)
FRONTEND_URL=https://carcatlog-frontend.onrender.com

# Stripe - Use LIVE keys for production
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# DVLA API
DVLA_API_KEY=
DVLA_API_URL=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# CheckCarDetails API
CHECKCARD_API_KEY=
CHECKCARD_API_BASE_URL=https://api.checkcardetails.co.uk

# Email
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=
EMAIL_FROM=CarCatalog <noreply@carcatalog.com>

# Google OAuth - Update callback to production URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://carcatlog-backend.onrender.com/api/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://carcatlog-backend.onrender.com/api/auth/facebook/callback

# API Cost Controls
DISABLE_PRESAVE_API_CALLS=false
API_DAILY_SPEND_CAP=5.00
API_MONTHLY_SPEND_CAP=50.00
ENABLE_PAYMENT_AUTOCOMPLETE=true

# Show only active cars in production
SHOW_DRAFT_CARS=false

# API Environment
API_ENVIRONMENT=production
FORCE_STRIPE=true
